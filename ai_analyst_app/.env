# ==========================================
# AI-Analyst PB Project Environment Variables
# ==========================================

# 1. LLM API Keys (사용할 모델의 키 입력)
OPENAI_API_KEY="여기에-OpenAI-키를-입력하세요"
# ANTHROPIC_API_KEY="여기에-Claude-키를-입력하세요"
# GOOGLE_API_KEY="여기에-Gemini-키를-입력하세요"

# 2. LangSmith Tracing (LangGraph 디버깅 및 에이전트 모니터링용)
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="여기에-LangSmith-키를-입력하세요"
LANGCHAIN_PROJECT="ai_analyst_app"

# 3. Naver Open API (최신 뉴스 검색용 - backend/services/tools.py에서 사용)
NAVER_CLIENT_ID="여기에-NAVER_CLIENT-ID를-입력하세요"
NAVER_CLIENT_SECRET="여기에-NAVER_CLIENT-비밀번호를-입력하세요"

# 4. FastAPI 설정
PROJECT_NAME="AI-Analyst PB Project"
PROJECT_VERSION="1.0.0"