# ==========================================
# 1. Python & Environment
# ==========================================
# 파이썬 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# 가상환경 (필요시)
venv/
.venv/
env/

# ==========================================
# 2. Security (가장 중요)
# ==========================================
# 환경변수 파일 (API Key 등 보안 정보)
.env
.env.*
secrets.json

# ==========================================
# 3. Data & Database (업로드 제외 대상)
# ==========================================
# 원본 및 라벨링 데이터 (ZIP 등 대용량 파일)
data/01.원천데이터/
data/02.라벨링데이터/

# ChromaDB 로컬 벡터 저장소
data/chroma_db/

# 정제된 CSV 데이터 및 리포트
data/processed/

# 로컬 지식 그래프 구조 파일
data/knowledge_graph.gml

# 로컬 채팅 로그
data/chat_history.json

# (선택) data 폴더 내 구조는 유지하되, 모든 내용물 무시
